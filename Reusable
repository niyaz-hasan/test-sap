name: Reusable Terraform Deploy

on:
  workflow_call:
    inputs:
      site:
        required: true
        type: string
      environment:
        required: true
        type: string
      apply_changes:
        required: false
        default: false
        type: boolean

permissions:
  id-token: write
  contents: read
  pull-requests: write

jobs:
  terraform:
    runs-on: ubuntu-latest
    environment: ${{ inputs.environment }}

    outputs:
      add: ${{ steps.summary.outputs.add }}
      change: ${{ steps.summary.outputs.change }}
      destroy: ${{ steps.summary.outputs.destroy }}

    env:
      AWS_ACCOUNT_ID: ${{ secrets.AWS_ACCOUNT_ID }}
      AWS_ROLE_NAME: ${{ secrets.AWS_ROLE_NAME }}
      AWS_REGION: ${{ vars.AWS_REGION }}
      S3_BUCKET: ${{ secrets.S3_BUCKET }}
      DYNAMODB_TABLE: ${{ secrets.DYNAMODB_TABLE }}

    steps:
      - uses: actions/checkout@v4

      - name: Set working dir
        run: |
          if [ "${{ inputs.site }}" = "common" ]; then
            echo "TF_WORKING_DIR=common-resources" >> $GITHUB_ENV
          else
            echo "TF_WORKING_DIR=sites/${{ inputs.site }}" >> $GITHUB_ENV
          fi
          echo "TF_VAR_FILE=${{ inputs.environment }}.tfvars" >> $GITHUB_ENV

      - name: Setup Terraform
        uses: hashicorp/setup-terraform@v3

      - name: Configure AWS (OIDC)
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::${{ env.AWS_ACCOUNT_ID }}:role/${{ env.AWS_ROLE_NAME }}
          aws-region: ${{ env.AWS_REGION }}

      - name: Terraform Init
        working-directory: ${{ env.TF_WORKING_DIR }}
        run: |
          terraform init -reconfigure \
            -backend-config="bucket=${{ env.S3_BUCKET }}" \
            -backend-config="key=${{ inputs.site }}/${{ inputs.environment }}/terraform.tfstate" \
            -backend-config="region=${{ env.AWS_REGION }}" \
            -backend-config="dynamodb_table=${{ env.DYNAMODB_TABLE }}"

      # 🔥 IMPORTANT STEP
      - name: Terraform Plan
        id: plan
        working-directory: ${{ env.TF_WORKING_DIR }}
        run: |
          set -o pipefail
          terraform plan -no-color \
            -var-file="${{ env.TF_VAR_FILE }}" \
            -out=tfplan \
            -detailed-exitcode | tee plan.txt

          EXITCODE=$?
          echo "exitcode=$EXITCODE" >> $GITHUB_OUTPUT

          if [ "$EXITCODE" -eq 1 ]; then
            exit 1
          fi

      # 🔥 SUMMARY PARSER
      - name: Parse plan summary
        id: summary
        working-directory: ${{ env.TF_WORKING_DIR }}
        run: |
          ADD=$(grep -oE '([0-9]+) to add' plan.txt | grep -oE '[0-9]+' || echo "0")
          CHANGE=$(grep -oE '([0-9]+) to change' plan.txt | grep -oE '[0-9]+' || echo "0")
          DESTROY=$(grep -oE '([0-9]+) to destroy' plan.txt | grep -oE '[0-9]+' || echo "0")

          echo "add=$ADD" >> $GITHUB_OUTPUT
          echo "change=$CHANGE" >> $GITHUB_OUTPUT
          echo "destroy=$DESTROY" >> $GITHUB_OUTPUT

      - name: Upload plan file
        uses: actions/upload-artifact@v4
        with:
          name: plan-${{ inputs.site }}
          path: ${{ env.TF_WORKING_DIR }}/plan.txt
